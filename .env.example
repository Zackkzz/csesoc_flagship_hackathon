# PromptLens environment example
# Copy to repo root as `.env` (Docker Compose) and/or `apps/api/.env` (local uvicorn).

# auto | openai | ollama
PROCESSING_PROVIDER=auto

# Cheap processing models only (never frontier for Improve/Judge/Strip)
IMPROVER_MODEL=gpt-4.1-mini
JUDGE_MODEL=gpt-4.1-mini
TARGET_MODEL=gpt-4.1-mini

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Local uvicorn: 127.0.0.1 — Docker Compose overrides to host.docker.internal
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# SQLite path (local). Docker uses sqlite:////data/promptlens.db via compose.
DATABASE_URL=sqlite:///./promptlens.db

# CORS for Vite dev + Docker web (port 8080)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080

# If no API key / Ollama: heuristic improve & strip still work
ALLOW_HEURISTIC_FALLBACK=true
